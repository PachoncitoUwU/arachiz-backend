generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  userType  String // 'instructor' or 'aprendiz'
  fullName  String
  document  String   @unique
  email     String   @unique
  password  String
  avatarUrl String?
  nfcUid    String?  @unique
  huellas   Int[]    @default([])
  createdAt DateTime @default(now())

  // Relations
  fichasAdmin Ficha[]              @relation("InstructorAdmin")
  fichasInst  FichaInstructor[]
  fichasApr   Ficha[]              @relation("Aprendices")
  materias    Materia[]            @relation("InstructorMaterias")
  asistencias Asistencia[]         @relation("InstructorAsistencia")
  registros   RegistroAsistencia[]
  excusas     Excusa[]
}

model Ficha {
  id        String   @id @default(cuid())
  numero    String   @unique
  nivel     String
  centro    String
  jornada   String
  region    String   @default("")
  duracion  Int      @default(0)
  code      String   @unique
  createdAt DateTime @default(now())

  instructorAdminId String
  instructorAdmin   User   @relation("InstructorAdmin", fields: [instructorAdminId], references: [id])

  instructores FichaInstructor[]
  aprendices   User[]            @relation("Aprendices")

  materias Materia[]
  horarios Horario[]
}

model FichaInstructor {
  id           String @id @default(cuid())
  role         String @default("invitado") // 'admin' | 'invitado'
  fichaId      String
  instructorId String
  ficha        Ficha  @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([fichaId, instructorId])
}

model Materia {
  id     String @id @default(cuid())
  nombre String
  tipo   String

  fichaId String
  ficha   Ficha  @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  instructorId String
  instructor   User   @relation("InstructorMaterias", fields: [instructorId], references: [id])

  asistencias Asistencia[]
  horarios    Horario[]
}

model Horario {
  id         String @id @default(cuid())
  dia        String // 'Lunes', 'Martes', etc.
  horaInicio String // '08:00'
  horaFin    String // '10:00'

  fichaId String
  ficha   Ficha  @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  materiaId String
  materia   Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
}

model Asistencia {
  id        String   @id @default(cuid())
  fecha     String
  activa    Boolean  @default(true)
  timestamp DateTime @default(now())

  materiaId String
  materia   Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  instructorId String
  instructor   User   @relation("InstructorAsistencia", fields: [instructorId], references: [id])

  registros RegistroAsistencia[]
}

model RegistroAsistencia {
  id        String   @id @default(cuid())
  presente  Boolean  @default(true)
  metodo    String   @default("manual") // 'qr', 'codigo', 'manual', 'facial', 'huella', 'nfc'
  timestamp DateTime @default(now())

  asistenciaId String
  asistencia   Asistencia @relation(fields: [asistenciaId], references: [id], onDelete: Cascade)

  aprendizId String
  aprendiz   User   @relation(fields: [aprendizId], references: [id], onDelete: Cascade)

  @@unique([asistenciaId, aprendizId])
}

model Excusa {
  id          String    @id @default(cuid())
  motivo      String
  descripcion String
  fechas      String // JSON array de fechas: '["2026-03-01","2026-03-02"]'
  estado      String    @default("Pendiente") // 'Pendiente', 'Aprobada', 'Rechazada'
  respuesta   String?
  archivoUrl  String?
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  aprendizId String
  aprendiz   User   @relation(fields: [aprendizId], references: [id], onDelete: Cascade)
}
